# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# System Configuration
TZ=Asia/Manila

# SMTP / Resend Configuration for Email Alerts
RESEND_API_KEY=
SMTP_FROM=
DESTINATION_EMAIL=
ENABLE_EMAIL_ALERTS=

# Authentication
JWT_SECRET=

# MySQL Database Configuration
DB_HOST=
DB_USER=
DB_PASSWORD=
# Use CUSTOM_DB_PASSWORD if the standard DB_PASSWORD gets auto-overridden by the platform's default database services.
CUSTOM_DB_PASSWORD=
DB_NAME=
DB_PORT=
DB_SSL=

# Google OAuth for User Guide Generation
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Backblaze B2 S3-Compatible File Storage (Optional - Falls back to database storage if empty)
B2_APPLICATION_KEY_ID=your_backblaze_b2_key_id
B2_APPLICATION_KEY=your_backblaze_b2_application_key
B2_BUCKET_NAME=your_bucket_name
B2_ENDPOINT=s3.us-west-004.backblazeb2.com
