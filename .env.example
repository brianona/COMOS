# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# System Configuration
TZ=Asia/Manila

# SMTP / Resend Configuration for Email Alerts
RESEND_API_KEY=re_123456789
SMTP_FROM=onboarding@resend.dev
DESTINATION_EMAIL=IT@cleanocean.com.ph
ENABLE_EMAIL_ALERTS=true

# Authentication
JWT_SECRET=some_random_secret_change_me

# MySQL Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=vessel_cert
DB_PORT=3306
DB_SSL=false

# Google OAuth for User Guide Generation
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Backblaze B2 S3-Compatible File Storage (Optional - Falls back to database storage if empty)
B2_APPLICATION_KEY_ID=your_backblaze_b2_key_id
B2_APPLICATION_KEY=your_backblaze_b2_application_key
B2_BUCKET_NAME=your_bucket_name
B2_ENDPOINT=s3.us-west-004.backblazeb2.com
